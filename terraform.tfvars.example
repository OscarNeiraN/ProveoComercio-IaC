project_name = "proveocomercio"
aws_region   = "us-east-1"

# Opcional. Si queda vacio, Terraform genera JWT_SECRET y lo guarda en AWS Secrets Manager.
# jwt_secret = "CHANGE_ME_LONG_RANDOM_VALUE"

subnets_config = {
  public_a = {
    az      = "us-east-1a"
    net_num = 1
    public  = true
  }
  public_b = {
    az      = "us-east-1b"
    net_num = 2
    public  = true
  }
  private_a = {
    az      = "us-east-1a"
    net_num = 10
    public  = false
  }
  private_b = {
    az      = "us-east-1b"
    net_num = 11
    public  = false
  }
}

alb_config = {
  name                 = "proveo-app-alb"
  internal             = false
  listener_port        = 80
  protocol             = "HTTP"
  frontend_port        = 80
  backend_port         = 3000
  backend_path_pattern = "/api/*"
  target_protocol      = "HTTP"
}

db_config = {
  engine                  = "mysql"
  engine_version          = "8.0"
  instance_class          = "db.t4g.micro"
  username                = "proveo_admin"
  password                = "CHANGE_ME_FROM_SECRET_OR_LOCAL_TFVARS"
  storage                 = 20
  name                    = "proveocomercio"
  publicly_accessible     = false
  multi_az                = false
  storage_encrypted       = true
  backup_retention_period = 7
  deletion_protection     = false
}

enable_backup = true

backup_config = {
  # Diario a las 05:00 UTC. En Chile queda de madrugada y evita horas de mayor uso.
  schedule                  = "cron(0 5 * * ? *)"
  start_window_minutes      = 60
  completion_window_minutes = 180
  retention_days            = 35

  # Vacio = vault cifrado con clave administrada por AWS Backup.
  # Si tienes una CMK propia, pega aqui su ARN.
  vault_kms_key_arn = ""

  # Cuenta normal: true crea un rol IAM dedicado para AWS Backup.
  # AWS Academy / Learner Lab: usa false y un rol existente como LabRole.
  create_iam_role  = true
  backup_role_name = ""
}

smtp_config = {
  host      = ""
  port      = 587
  user      = ""
  password  = ""
  secure    = false
  mail_from = ""
}

# Correo que recibe las alarmas de CloudWatch via SNS. SNS manda un correo de
# confirmacion la primera vez: hay que aceptar la suscripcion o no llegan las alertas.
alert_email = "CHANGE_ME@example.com"

# Auditoria de quien crea/modifica/borra recursos en la cuenta AWS. Gratis para
# management events (primera copia por region); solo paga el storage minimo en S3.
# enable_cloudtrail             = true
# cloudtrail_log_retention_days = 180

# AWS Academy / Learner Lab:
# create_iam_roles         = false
# task_execution_role_name = "LabRole"
# task_role_name           = "LabRole"
# enable_ecs_autoscaling   = false
