        <!-- Flow notes -->
        <mxCell id="flow-note" value="Flujo principal&lt;br&gt;1. Usuario entra por ALB publico y frontend.&lt;br&gt;2. Frontend reenvia /api al ALB interno.&lt;br&gt;3. Backend valida y descuenta stock en RDS, guarda pedido y publica mensaje en SQS.&lt;br&gt;4. Worker consume SQS, genera boleta/correo y actualiza RDS." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E6;strokeColor=#FF9900;fontColor=#232F3E;align=left;verticalAlign=top;spacing=12;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="240" y="965" width="630" height="105" as="geometry" />
        </mxCell>

        <mxCell id="security-note" value="Exposicion&lt;br&gt;Solo el ALB publico recibe trafico desde Internet. Backend, worker y RDS quedan en subredes privadas sin IP publica." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDECEC;strokeColor=#DD344C;fontColor=#232F3E;align=left;verticalAlign=top;spacing=12;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="910" y="965" width="440" height="105" as="geometry" />
        </mxCell>

